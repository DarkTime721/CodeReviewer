LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=PASTE_KEY_HERE
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_PROJECT=code-reviewer

GITHUB_TOKEN = PASTE_KEY_HERE

# Switch this to openai / groq / ollama
LLM_PROVIDER=ollama

# Ollama (no API key required)
OLLAMA_CLASSIFIER=qwen2.5-coder
OLLAMA_JUDGE_MODEL=qwen3.5:9b
OLLAMA_SPECIALIST_MODEL=qwen2.5-coder:14b
OLLAMA_DEFAULT_MODEL=qwen2.5-coder:14b

# OpenAI (uncomment if using)
# OPENAI_API_KEY=PASTE_KEY_HERE
# OPENAI_CLASSIFIER=gpt-4o-mini
# OPENAI_JUDGE_MODEL=gpt-4o
# OPENAI_SPECIALIST_MODEL=gpt-4o-mini
# OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Groq (uncomment if using)
# GROQ_API_KEY=PASTE_KEY_HERE
# GROQ_CLASSIFIER=openai/gpt-oss-120b
# GROQ_JUDGE_MODEL=openai/gpt-oss-120b
# GROQ_SPECIALIST_MODEL=openai/gpt-oss-120b
# GROQ_DEFAULT_MODEL=openai/gpt-oss-120b